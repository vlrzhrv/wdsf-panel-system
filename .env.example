# ── WDSF API credentials ────────────────────────────────
WDSF_USER=your_wdsf_username
WDSF_PASS=your_wdsf_password

# ── App access password (shown to users opening the URL) ─
APP_USER=wdsf
APP_PASSWORD=choose_a_strong_password

# ── Flask secret key (any random string) ─────────────────
SECRET_KEY=change-this-to-something-random-and-long
